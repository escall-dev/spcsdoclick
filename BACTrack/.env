# SDO-BACtrack environment configuration
# Fill in secret values before deploying.

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
APP_NAME="SDO-BACTrack"
APP_TITLE="SDO-BACTrack"
APP_SUBTITLE="Procurement, Bids and Awards Committee Timeline Tracker"
APP_VERSION=1.0.0
APP_URL=/BACTrack
SYSTEM_BASE_URL=https://spcsdoclick.com/BACTrack
TIMEZONE=Asia/Manila

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u813957308_sdo_bac
DB_USER=u813957308_BACsdospc
DB_PASS=BAC12345sanpedro
DB_CHARSET=utf8mb4

# ------------------------------------------------------------
# Session and auth
# ------------------------------------------------------------
SESSION_NAME=sdo_bactrack_session
SESSION_LIFETIME=28800
AUTH_TOKEN_PARAM=auth_token

# ------------------------------------------------------------
# Upload and notifications
# ------------------------------------------------------------
MAX_FILE_SIZE=10485760
DEADLINE_WARNING_DAYS=2

# ------------------------------------------------------------
# Google OAuth (optional)
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://spcsdoclick.com/BACtrack/admin/auth/google-callback.php

# ------------------------------------------------------------
# Mail / SMTP (optional)
# ------------------------------------------------------------
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_AUTH=true
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="SDO-BACtrack"
MAIL_REPLY_TO=
ADMIN_EMAIL_RECIPIENTS=
MAIL_DEBUG=0
