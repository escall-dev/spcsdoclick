# ============================================
# Centralized Environment Variables
# ============================================

# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=3306
DB_CHARSET=utf8mb4

# CTS Database
CTS_DB_NAME=u813957308_sdo_cts
CTS_DB_USER=sdo_cts
CTS_DB_PASS=Sdosanpedro2021

# BACTrack Database
BAC_DB_NAME=u813957308_sdo_bac
BAC_DB_USER=u813957308_BACsdospc
BAC_DB_PASS=BAC12345sanpedro

# --- Common Settings ---
TIMEZONE=Asia/Manila

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CTS_GOOGLE_REDIRECT_URI=https://spcsdoclick.com/CTS/admin/auth/google-callback.php
BAC_GOOGLE_REDIRECT_URI=https://spcsdoclick.com/BACTrack/admin/auth/google-callback.php

# --- Email Configuration (PHPMailer with SMTP) ---
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls

# CTS Email Settings
CTS_MAIL_FROM_ADDRESS=
CTS_MAIL_FROM_NAME="SDO CTS - The Schools Division Office of San Pedro City"
CTS_MAIL_REPLY_TO=
CTS_ADMIN_EMAIL_RECIPIENTS=
CTS_SYSTEM_BASE_URL=https://spcsdoclick.com/CTS

# BACTrack Email Settings
BAC_MAIL_FROM_ADDRESS=
BAC_MAIL_FROM_NAME="SDO-BACtrack"
BAC_MAIL_REPLY_TO=
BAC_ADMIN_EMAIL_RECIPIENTS=
BAC_SYSTEM_BASE_URL=https://spcsdoclick.com/BACTrack

# --- Application Specific (BACTrack) ---
APP_ENV=local
APP_DEBUG=true
APP_NAME="SDO-BACTrack"
APP_TITLE="SDO-BACTrack"
APP_SUBTITLE="Procurement, Bids and Awards Committee Timeline Tracker"
APP_VERSION=1.0.0
APP_URL=/BACTrack
SESSION_NAME=sdo_bactrack_session
SESSION_LIFETIME=28800
AUTH_TOKEN_PARAM=auth_token
MAX_FILE_SIZE=10485760
DEADLINE_WARNING_DAYS=2
